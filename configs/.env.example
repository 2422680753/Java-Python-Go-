# Kafka配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=risk-control-system

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# Java服务配置
SPRING_PROFILES_ACTIVE=dev

# 交易网关服务
GATEWAY_PORT=8080

# 规则引擎服务
RULES_PORT=8081

# 实时决策服务
DECISION_PORT=8082

# Python服务配置
ML_SERVICE_PORT=8083

# Go服务配置
DATA_PROCESSING_PORT=8084
STREAM_PROCESSING_PORT=8085
CACHE_MANAGEMENT_PORT=8086

# 日志级别
LOG_LEVEL=INFO

# 监控配置
METRICS_ENABLED=true
