FROM golang:1.21-alpine AS build

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY cache-management/ ./cache-management/

WORKDIR /app/cache-management

RUN CGO_ENABLED=0 GOOS=linux go build -o /cache-management-service .

FROM alpine:latest

WORKDIR /app

RUN addgroup -S riskcontrol && adduser -S riskcontrol -G riskcontrol

COPY --from=build /cache-management-service .

RUN chown -R riskcontrol:riskcontrol /app

USER riskcontrol

EXPOSE 8086

CMD ["./cache-management-service"]
