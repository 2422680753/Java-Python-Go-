FROM golang:1.21-alpine AS build

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY data-processing/ ./data-processing/

WORKDIR /app/data-processing

RUN CGO_ENABLED=0 GOOS=linux go build -o /data-processing-service .

FROM alpine:latest

WORKDIR /app

RUN addgroup -S riskcontrol && adduser -S riskcontrol -G riskcontrol

COPY --from=build /data-processing-service .

RUN chown -R riskcontrol:riskcontrol /app

USER riskcontrol

EXPOSE 8084

CMD ["./data-processing-service"]
