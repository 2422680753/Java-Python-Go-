FROM golang:1.21-alpine AS build

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY stream-processing/ ./stream-processing/

WORKDIR /app/stream-processing

RUN CGO_ENABLED=0 GOOS=linux go build -o /stream-processing-service .

FROM alpine:latest

WORKDIR /app

RUN addgroup -S riskcontrol && adduser -S riskcontrol -G riskcontrol

COPY --from=build /stream-processing-service .

RUN chown -R riskcontrol:riskcontrol /app

USER riskcontrol

EXPOSE 8085

CMD ["./stream-processing-service"]
