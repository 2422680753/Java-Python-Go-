FROM maven:3.9-eclipse-temurin-17 AS build

WORKDIR /app

COPY pom.xml .
COPY realtime-decision/pom.xml ./realtime-decision/

RUN mvn dependency:go-offline -B

COPY realtime-decision/src ./realtime-decision/src

RUN mvn clean package -DskipTests -pl realtime-decision -am

FROM eclipse-temurin:17-jre-alpine

WORKDIR /app

RUN addgroup -S riskcontrol && adduser -S riskcontrol -G riskcontrol

COPY --from=build /app/realtime-decision/target/*.jar app.jar

RUN chown -R riskcontrol:riskcontrol /app

USER riskcontrol

EXPOSE 8082

ENV JAVA_OPTS="-Xms256m -Xmx512m -XX:+UseG1GC"

ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]
