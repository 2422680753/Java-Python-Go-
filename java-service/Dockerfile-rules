FROM maven:3.9-eclipse-temurin-17 AS build

WORKDIR /app

COPY pom.xml .
COPY rules-engine/pom.xml ./rules-engine/

RUN mvn dependency:go-offline -B

COPY rules-engine/src ./rules-engine/src

RUN mvn clean package -DskipTests -pl rules-engine -am

FROM eclipse-temurin:17-jre-alpine

WORKDIR /app

RUN addgroup -S riskcontrol && adduser -S riskcontrol -G riskcontrol

COPY --from=build /app/rules-engine/target/*.jar app.jar

RUN chown -R riskcontrol:riskcontrol /app

USER riskcontrol

EXPOSE 8081

ENV JAVA_OPTS="-Xms512m -Xmx1g -XX:+UseG1GC"

ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]
