package com.riskcontrol.rules

import com.riskcontrol.rules.model.TransactionFact
import java.math.BigDecimal

global java.util.Map riskFactors
global com.riskcontrol.rules.config.DynamicThresholdConfig thresholdConfig

rule "大额交易白名单豁免"
    salience 150
    when
        $fact: TransactionFact(amount >= new BigDecimal("100000"))
        eval(thresholdConfig.isWhitelisted("user", $fact.getUserId()) ||
             thresholdConfig.isWhitelisted("account", $fact.getAccountId()))
    then
        $fact.setRuleRiskScore(0.0);
        $fact.setRuleDecision("APPROVE");
        $fact.setRuleReason("大额交易白名单用户，自动通过");
        drools.halt();
end

rule "VIP用户豁免"
    salience 140
    when
        $fact: TransactionFact()
        eval(thresholdConfig.isWhitelisted("vip", $fact.getUserId()))
    then
        WhitelistRule rule = thresholdConfig.getWhitelistRule("vip", $fact.getUserId());
        if (rule != null && rule.isAutoApprove()) {
            if (rule.getMaxAmount() != null && 
                $fact.getAmount().compareTo(rule.getMaxAmount()) > 0) {
                $fact.setRuleRiskScore(0.1);
                $fact.setRuleDecision("REVIEW");
                $fact.setRuleReason("VIP用户但金额超限，需要审核");
            } else {
                $fact.setRuleRiskScore(0.0);
                $fact.setRuleDecision("APPROVE");
                $fact.setRuleReason("VIP用户，自动通过");
            }
            drools.halt();
        }
end

rule "大额交易风险 - 动态评分"
    salience 100
    when
        $fact: TransactionFact(amount >= thresholdConfig.getLargeTransactionThreshold(),
                              amount < thresholdConfig.getVeryLargeThreshold())
    then
        double baseScore = 0.25;
        
        if ($fact.getUserTransactionCount() > 100) {
            baseScore *= 0.7;
        }
        
        if ($fact.isNewDevice()) {
            baseScore += 0.1;
        }
        if ($fact.isNewLocation()) {
            baseScore += 0.1;
        }
        
        $fact.setRuleRiskScore($fact.getRuleRiskScore() + baseScore);
        $fact.setRuleReason("大额交易: 金额超过" + thresholdConfig.getLargeTransactionThreshold().toString());
end

rule "超大额交易风险 - 特殊处理"
    salience 105
    when
        $fact: TransactionFact(amount >= thresholdConfig.getVeryLargeThreshold())
    then
        double baseScore = 0.4;
        
        if ($fact.getUserTransactionCount() > 500) {
            baseScore *= 0.6;
        }
        
        if (!$fact.isNewUser() && !$fact.isNewDevice() && !$fact.isNewLocation()) {
            baseScore *= 0.7;
        }
        
        if ($fact.getUserDailyAmount().compareTo(new BigDecimal("1000000")) > 0) {
            baseScore += 0.15;
        }
        
        $fact.setRuleRiskScore($fact.getRuleRiskScore() + baseScore);
        $fact.setRuleReason("超大额交易: 金额超过" + thresholdConfig.getVeryLargeThreshold().toString());
end

rule "新用户首次交易风险 - 优化"
    salience 90
    when
        $fact: TransactionFact(isNewUser == true, userTransactionCount == 0)
    then
        double score = 0.15;
        
        if ($fact.getAmount().compareTo(new BigDecimal("10000")) > 0) {
            score += 0.1;
        }
        
        if (!$fact.isNewDevice() && !$fact.isNewLocation()) {
            score *= 0.5;
        }
        
        $fact.setRuleRiskScore($fact.getRuleRiskScore() + score);
        $fact.setRuleReason("新用户首次交易");
end

rule "新设备交易风险 - 优化"
    salience 80
    when
        $fact: TransactionFact(isNewDevice == true)
    then
        double score = 0.1;
        
        if ($fact.getAmount().compareTo(new BigDecimal("50000")) > 0) {
            score += 0.1;
        }
        
        if (!$fact.isNewUser() && !$fact.isNewLocation()) {
            score *= 0.6;
        }
        
        $fact.setRuleRiskScore($fact.getRuleRiskScore() + score);
        $fact.setRuleReason("新设备登录交易");
end

rule "新位置交易风险 - 优化"
    salience 80
    when
        $fact: TransactionFact(isNewLocation == true)
    then
        double score = 0.1;
        
        if ($fact.getAmount().compareTo(new BigDecimal("50000")) > 0) {
            score += 0.1;
        }
        
        if (!$fact.isNewUser() && !$fact.isNewDevice()) {
            score *= 0.6;
        }
        
        $fact.setRuleRiskScore($fact.getRuleRiskScore() + score);
        $fact.setRuleReason("新地理位置交易");
end

rule "登录失败多次风险"
    salience 95
    when
        $fact: TransactionFact(userLoginFailures >= 3)
    then
        double score = 0.3;
        
        if ($fact.getUserLoginFailures() >= 5) {
            score = 0.5;
        }
        
        $fact.setRuleRiskScore($fact.getRuleRiskScore() + score);
        $fact.setRuleReason("登录失败" + $fact.getUserLoginFailures() + "次以上，存在账户被盗风险");
        
        if ($fact.getRuleRiskScore() >= 0.7) {
            $fact.setRuleDecision("REJECT");
        }
end

rule "单日累计金额过高风险 - 优化"
    salience 85
    when
        $fact: TransactionFact(userDailyAmount > thresholdConfig.getMaxDailyAmount())
    then
        double score = 0.2;
        
        BigDecimal dailyAmount = $fact.getUserDailyAmount();
        if (dailyAmount.compareTo(new BigDecimal("1000000")) > 0) {
            score = 0.3;
        }
        
        $fact.setRuleRiskScore($fact.getRuleRiskScore() + score);
        $fact.setRuleReason("单日累计交易金额超过" + thresholdConfig.getMaxDailyAmount().toString());
end

rule "高风险国家交易"
    salience 95
    when
        $fact: TransactionFact(isHighRiskCountry == true)
    then
        $fact.setRuleRiskScore($fact.getRuleRiskScore() + 0.4);
        $fact.setRuleReason("交易来自高风险国家/地区");
        $fact.setRuleDecision("REJECT");
end

rule "可疑收款方交易"
    salience 90
    when
        $fact: TransactionFact(isSuspiciousRecipient == true)
    then
        $fact.setRuleRiskScore($fact.getRuleRiskScore() + 0.35);
        $fact.setRuleReason("收款方为可疑账户");
end

rule "高频交易风险"
    salience 88
    when
        $fact: TransactionFact(userTransactionCount > thresholdConfig.getMaxTransactionPerHour())
    then
        double score = 0.15;
        
        if ($fact.getUserTransactionCount() > 200) {
            score = 0.25;
        }
        
        $fact.setRuleRiskScore($fact.getRuleRiskScore() + score);
        $fact.setRuleReason("高频交易: 超过" + thresholdConfig.getMaxTransactionPerHour() + "笔/小时");
end

rule "综合风险评估 - 高风险 (优化阈值 0.8)"
    salience 50
    when
        $fact: TransactionFact(ruleRiskScore >= 0.8, ruleDecision == null || ruleDecision == "REVIEW")
    then
        $fact.setRuleDecision("REJECT");
        $fact.setRuleReason("综合风险评分过高: " + String.format("%.2f", $fact.getRuleRiskScore()) + "，交易被拒绝");
end

rule "综合风险评估 - 中高风险 (0.6-0.8)"
    salience 48
    when
        $fact: TransactionFact(ruleRiskScore >= 0.6, ruleRiskScore < 0.8, ruleDecision == null)
    then
        $fact.setRuleDecision("REVIEW");
        $fact.setRuleReason("中高风险: " + String.format("%.2f", $fact.getRuleRiskScore()) + "，需要重点审核");
end

rule "综合风险评估 - 中等风险 (0.4-0.6)"
    salience 46
    when
        $fact: TransactionFact(ruleRiskScore >= 0.4, ruleRiskScore < 0.6, ruleDecision == null)
    then
        $fact.setRuleDecision("REVIEW");
        $fact.setRuleReason("中等风险: " + String.format("%.2f", $fact.getRuleRiskScore()) + "，需要审核");
end

rule "综合风险评估 - 低风险 (0.25-0.4)"
    salience 44
    when
        $fact: TransactionFact(ruleRiskScore >= 0.25, ruleRiskScore < 0.4, ruleDecision == null)
    then
        $fact.setRuleDecision("APPROVE");
        $fact.setRuleReason("中低风险: " + String.format("%.2f", $fact.getRuleRiskScore()) + "，自动通过");
end

rule "综合风险评估 - 极低风险 (< 0.25)"
    salience 42
    when
        $fact: TransactionFact(ruleRiskScore < 0.25, ruleDecision == null)
    then
        $fact.setRuleDecision("APPROVE");
        $fact.setRuleReason("低风险: " + String.format("%.2f", $fact.getRuleRiskScore()) + "，自动通过");
end

rule "默认决策"
    salience 1
    when
        $fact: TransactionFact(ruleDecision == null)
    then
        $fact.setRuleDecision("REVIEW");
        $fact.setRuleReason("需要人工审核");
end
